# Modèles générés (poids, adaptateurs, GGUF) — racine uniquement.
# (Ancré avec / pour ne PAS exclure api/app/models/.)
/models/
!/models/.gitkeep

# Documents officiels téléchargés (sources brutes du corpus RAG) — volumineux,
# reconstructibles depuis corpus/sources/sources_officielles.yaml
/train/
!/train/.gitkeep

# Corpus RAG généré — gardé PRIVÉ (le dépôt est public). On l'amène aux pods
# via runpodctl (transfert direct), jamais via git. Le corpus de démarrage
# (corpus_cacao_demarrage.jsonl) reste suivi, lui.
corpus/corpus_cacao_rag.jsonl

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
.env

# Outils
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# État local du harness Claude Code
.claude/

# Binaire CLI RunPod (téléchargé pour les transferts de fichiers, non versionné)
runpodctl
runpodctl*.exe

# Clés SSH RunPod et archives locales — JAMAIS versionnées (secret / volumineux)
runpod
runpod.pub
*.tar.gz
*.gguf

# Kubeconfig (accès cluster) — JAMAIS versionné
kubeconfig*
*.kubeconfig
k3s*.yaml

# Système
.DS_Store
*.log
~WRL*.tmp

# Captures d'écran / documents de travail (non versionnés, peuvent contenir
# des infos personnelles : facturation, etc.)
docs/Doc2.*
~$*

# Override docker local (CORS démo, non versionné)
docker-compose.local.yml
