# Backend d'inférence : "vllm" (GPU) ou "llama-cpp" (CPU)
INFERENCE_BACKEND=vllm

# URL interne du service d'inférence (API OpenAI-compatible)
INFERENCE_URL=http://inference:8000

# Nom/chemin du modèle servi
MODEL_PATH=/models/opencacao-8b
MODEL_NAME=opencacao-8b

# Cache et rate-limit
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_PER_MIN=20

# Journalisation
LOG_LEVEL=INFO

# Journaliser les questions (anonymisées) pour enrichir le corpus — opt-in
LOG_QUESTIONS=false

# CORS — origines autorisées en production (séparées par des virgules)
CORS_ORIGINS=

# Durcissement (OWASP)
# Hôtes autorisés (TrustedHostMiddleware) — restreindre en prod, ex: api.opencacao.ci
ALLOWED_HOSTS=*
# Faire confiance à X-Forwarded-For (uniquement derrière un proxy de confiance)
TRUST_FORWARDED_FOR=false
# Taille max du corps de requête en octets (anti-DoS)
MAX_BODY_BYTES=16384
# Exposer la doc OpenAPI/Swagger (désactiver en production : false)
ENABLE_DOCS=true

# Token Hugging Face — requis pour télécharger Ministral 3 8B (modèle gated).
# Utilisé par la démo `make demo-base` (vLLM) ET par l'entraînement.
# Obtenir : accepter la licence sur huggingface.co/mistralai/Ministral-3-8B-Instruct-2512
# puis créer un token Read sur huggingface.co/settings/tokens
HF_TOKEN=

# --- Enrichissement du corpus avec un modèle-maître externe (HORS PRODUCTION) ---
# Toléré et signalé (CLAUDE §13) : sert UNIQUEMENT à générer un corpus Q/R de
# meilleure qualité (cf. training/scripts/generate_glm.sh). Jamais en production.
# GLM-5.2 via Z.ai (OpenAI-compatible, MIT) : clé API à obtenir sur z.ai.
ZAI_API_KEY=
# Surcharges optionnelles (défauts : endpoint Z.ai + modèle glm-5.2) :
# CORPUS_LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
# CORPUS_LLM_MODEL=glm-5.2
